# ===========================================================================
# MaybeTomorrow.store — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the blanks. Never commit the real
# `.env` — it contains secrets.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database — Postgres connection string.
# On mahelya the Docker Postgres container listens on :5432.
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/maybetomorrow

# ---------------------------------------------------------------------------
# NextAuth v5
# NEXTAUTH_URL should match the public origin in production
# (e.g. https://maybetomorrow.store).
# Regenerate secrets with: openssl rand -hex 32
# ---------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=REPLACE_WITH_openssl_rand_-hex_32
AUTH_SECRET=REPLACE_WITH_openssl_rand_-hex_32
AUTH_TRUST_HOST=true

# ---------------------------------------------------------------------------
# Anthropic — Claude API key for AI features
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Exchange rates — KES -> USD/EUR/CHF
# Default endpoint is exchangerate.host; override if you use a different
# provider (e.g. openexchangerates.org).
# ---------------------------------------------------------------------------
EXCHANGE_RATE_API=https://api.exchangerate.host/live

# ---------------------------------------------------------------------------
# WhatsApp click-to-chat
# International format, include the leading + and country code.
# ---------------------------------------------------------------------------
CLAURICE_WHATSAPP_PHONE=+254700000000

# ---------------------------------------------------------------------------
# Uploads
# UPLOAD_DIR is the absolute filesystem path where Next.js writes uploads.
# PUBLIC_UPLOAD_URL is the URL prefix Nginx serves those files under.
# See deploy/nginx-maybetomorrow.conf (`location /uploads/`).
# ---------------------------------------------------------------------------
UPLOAD_DIR=/var/mt-store/uploads
PUBLIC_UPLOAD_URL=/uploads

# ---------------------------------------------------------------------------
# Platform
# ---------------------------------------------------------------------------
PLATFORM_NAME=MaybeTomorrow.store
PLATFORM_MARGIN_PCT=10
APEX_DOMAIN=maybetomorrow.store

# ---------------------------------------------------------------------------
# App runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3003
